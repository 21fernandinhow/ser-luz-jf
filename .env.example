# --- Postgres (Supabase) — Prisma ---
# Pooler (Transaction mode): use ?pgbouncer=true na connection string do dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Conexão direta (migrations) — porta 5432, sem pgbouncer
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Supabase (Project Settings → API) ---
# URL e anon: também expostos ao browser via NUXT_PUBLIC_* (módulo @nuxtjs/supabase)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

NUXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NUXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Se omitir as duas linhas acima, o dev usa fallback local (127.0.0.1:54321) só para a app subir; em produção defina sempre o projeto real.

# Apenas servidor (nunca commitar valores reais)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# JWT Secret — Settings → API → JWT Secret (validação server-side nas próximas etapas)
SUPABASE_JWT_SECRET="your-jwt-secret"

# Opcional: textos/URLs públicas do modal de doação (Etapa 6+)
# NUXT_PUBLIC_DONATE_PIX_KEY=""
